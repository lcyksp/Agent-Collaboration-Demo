APP_ENV=dev
APP_DEBUG=true
APP_VERSION=0.1.0

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/tech_copilot
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT_SECONDS=30
POSTGRES_POOL_RECYCLE_SECONDS=1800

LLM_DEFAULT_MODEL=ollama/gemma3:4b
LLM_TIMEOUT_SECONDS=60
LITELLM_API_BASE=
LITELLM_API_KEY=

LANGGRAPH_CHECKPOINT_NAMESPACE=tech_copilot
LANGGRAPH_CHECKPOINT_TABLE=langgraph_checkpoints
